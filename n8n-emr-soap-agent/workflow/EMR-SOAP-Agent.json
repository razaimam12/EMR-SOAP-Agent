      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n<meta charset=\"UTF-8\" />\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\r\n<title>EMR SOAP Draft Agent</title>\r\n<style>\r\n  * { box-sizing:border-box; }\r\n  body { font-family:'Segoe UI',system-ui,sans-serif; background:#0f172a; margin:0; padding:2rem; color:#e2e8f0; }\r\n  .wrap { max-width:900px; margin:0 auto; }\r\n  h1 { font-size:1.4rem; margin:0 0 .25rem; }\r\n  .sub { color:#94a3b8; margin:0 0 1rem; font-size:.9rem; }\r\n  label { display:block; font-weight:600; margin:.6rem 0 .3rem; font-size:.85rem; }\r\n  input, textarea, select { width:100%; padding:.55rem .7rem; border-radius:8px; border:1px solid #334155; background:#1e293b; color:#e2e8f0; font:inherit; }\r\n  textarea { min-height:120px; }\r\n  details { background:#111c33; border:1px solid #24304a; border-radius:8px; padding:.4rem .8rem; margin-bottom:1rem; }\r\n  summary { cursor:pointer; font-weight:600; font-size:.85rem; color:#93c5fd; }\r\n  .fields { display:flex; gap:.6rem; flex-wrap:wrap; }\r\n  .f-name { flex:2 1 220px; } .f-mr { flex:1 1 150px; } .f-prov { flex:1 1 170px; }\r\n  .f-age { flex:1 1 90px; } .f-sex { flex:1 1 120px; } .f-wt { flex:1 1 110px; }\r\n  .bulletbar { display:flex; align-items:center; justify-content:space-between; }\r\n  .mic { background:#334155; color:#fff; border:none; padding:.35rem .7rem; border-radius:8px; font-size:.8rem; cursor:pointer; }\r\n  .mic.rec { background:#dc2626; }\r\n  .row { display:flex; gap:.5rem; margin-top:.75rem; flex-wrap:wrap; }\r\n  button.act { background:#0d9488; color:#fff; border:none; padding:.7rem 1.2rem; border-radius:8px; font-weight:600; cursor:pointer; }\r\n  button.secondary { background:#334155; color:#fff; border:none; padding:.7rem 1.2rem; border-radius:8px; font-weight:600; cursor:pointer; }\r\n  button:disabled { opacity:.5; cursor:not-allowed; }\r\n  .paper { background:#fff; color:#0f172a; border-radius:10px; padding:1.6rem 1.8rem; margin-top:1.25rem; box-shadow:0 6px 24px rgba(0,0,0,.25); line-height:1.5; display:none; }\r\n  .paper.show { display:block; }\r\n  .lh { display:flex; align-items:center; gap:.8rem; }\r\n  .lh img { height:52px; width:auto; }\r\n  .clinic { font-weight:700; font-size:1.15rem; color:#0f172a; }\r\n  .clinic small { display:block; font-weight:400; color:#64748b; font-size:.78rem; }\r\n  .hgrid { display:flex; flex-wrap:wrap; gap:.25rem 1.5rem; font-size:.9rem; color:#334155; border-bottom:2px solid #e2e8f0; padding-bottom:.6rem; margin:.4rem 0 .2rem; }\r\n  .doc-title { font-size:1.05rem; font-weight:700; color:#0d9488; border-bottom:2px solid #e2e8f0; padding-bottom:.5rem; margin-bottom:.5rem; }\r\n  .sec { font-weight:700; color:#0f766e; margin-top:1rem; margin-bottom:.2rem; letter-spacing:.02em; }\r\n  .ln { color:#1e293b; white-space:pre-wrap; }\r\n  .alert { background:#fef2f2; color:#b91c1c; border-left:4px solid #dc2626; padding:.5rem .75rem; margin:.5rem 0; font-weight:600; border-radius:4px; }\r\n  .meta { color:#94a3b8; font-size:.8rem; margin-top:1rem; }\r\n  .disc { color:#64748b; font-size:.8rem; font-style:italic; margin-top:.35rem; }\r\n  .triage { padding:.6rem .9rem; border-radius:6px; font-weight:700; margin-bottom:.9rem; }\r\n  .triage-emergency { background:#fee2e2; color:#991b1b; border-left:5px solid #dc2626; }\r\n  .triage-urgent { background:#fef3c7; color:#92400e; border-left:5px solid #d97706; }\r\n  .triage-routine { background:#dcfce7; color:#166534; border-left:5px solid #16a34a; }\r\n  .sp { height:.4rem; }\r\n  .sign { margin-top:1.5rem; padding-top:.8rem; border-top:1px dashed #94a3b8; font-size:.9rem; color:#1e293b; }\r\n  .sign .sigline { margin-top:.6rem; }\r\n  #editor { min-height:340px; margin-top:1.25rem; display:none; font-family:ui-monospace,Consolas,monospace; font-size:.85rem; }\r\n  .status { margin-top:1rem; color:#94a3b8; font-size:.9rem; }\r\n  #printarea { display:none; }\r\n  @media print {\r\n    body { background:#fff !important; padding:0; color:#000; }\r\n    body.printing-doc > *:not(#printarea) { display:none !important; }\r\n    #printarea { display:block !important; background:#fff; color:#0f172a; padding:0 6mm; }\r\n  }\r\n</style>\r\n</head>\r\n<body>\r\n<div class=\"wrap\">\r\n  <h1>EMR SOAP Draft Agent</h1>\r\n  <p class=\"sub\">Enter patient details and clinical bullet points. Returns a DRAFT SOAP note plus decision support for physician review - not a signed record.</p>\r\n\r\n  <div class=\"fields\">\r\n    <div class=\"f-name\"><label for=\"pname\">Patient name *</label><input id=\"pname\" type=\"text\" placeholder=\"e.g. Jane Doe\" /></div>\r\n    <div class=\"f-mr\"><label for=\"mrn\">MR number *</label><input id=\"mrn\" type=\"text\" placeholder=\"auto if left blank\" /></div>\r\n    <div class=\"f-prov\"><label for=\"prov\">Provider (optional)</label><input id=\"prov\" type=\"text\" placeholder=\"name - Dr. added automatically\" /></div>\r\n  </div>\r\n  <div class=\"fields\">\r\n    <div class=\"f-age\"><label for=\"age\">Age</label><input id=\"age\" type=\"number\" min=\"0\" max=\"130\" placeholder=\"yrs\" /></div>\r\n    <div class=\"f-sex\"><label for=\"sex\">Sex</label><select id=\"sex\"><option value=\"\">-</option><option>Male</option><option>Female</option><option>Other</option></select></div>\r\n    <div class=\"f-wt\"><label for=\"weight\">Weight (kg)</label><input id=\"weight\" type=\"number\" min=\"0\" step=\"0.1\" placeholder=\"kg\" /></div>\r\n  </div>\r\n  <div class=\"bulletbar\">\r\n    <label for=\"bullets\">Clinical bullet points</label>\r\n    <button id=\"mic\" type=\"button\" class=\"mic\">\ud83c\udfa4 Speak</button>\r\n  </div>\r\n  <textarea id=\"bullets\" placeholder=\"e.g. chest pain on exertion 2 days, radiates to left arm, SOB. BP 158/94, HR 98. Hx hypertension. Meds: amlodipine. Allergy: penicillin.\"></textarea>\r\n  <div class=\"row\">\r\n    <button id=\"run\" type=\"button\" class=\"act\">Generate SOAP Draft</button>\r\n    <button id=\"edit\" type=\"button\" class=\"secondary\" disabled>Edit note</button>\r\n    <button id=\"copy\" type=\"button\" class=\"secondary\" disabled>Copy note</button>\r\n    <button id=\"pdf\" type=\"button\" class=\"secondary\" disabled>Download PDF</button>\r\n    <button id=\"rx\" type=\"button\" class=\"secondary\" disabled>Rx slip (PDF)</button>\r\n    <button id=\"handout\" type=\"button\" class=\"secondary\" disabled>Patient handout (PDF)</button>\r\n  </div>\r\n  <div id=\"status\" class=\"status\">Ready.</div>\r\n  <textarea id=\"editor\"></textarea>\r\n  <div id=\"paper\" class=\"paper\">\r\n    <div id=\"phead\"></div>\r\n    <div id=\"body\"></div>\r\n    <div id=\"sign\" class=\"sign\"></div>\r\n  </div>\r\n</div>\r\n<div id=\"printarea\"></div>\r\n<script>\r\n  var $=function(id){return document.getElementById(id);};\r\n  var btn=$('run'), editBtn=$('edit'), copyBtn=$('copy'), pdfBtn=$('pdf'), rxBtn=$('rx'), handoutBtn=$('handout'),\r\n      micBtn=$('mic'), statusEl=$('status'), paper=$('paper'), bodyEl=$('body'), phead=$('phead'), signEl=$('sign'),\r\n      editor=$('editor'), pname=$('pname'), mrn=$('mrn'), prov=$('prov'), ageEl=$('age'), sexEl=$('sex'),\r\n      weightEl=$('weight'), bulletsEl=$('bullets');\r\n  var noteBody='', headerText='', signText='', lastMR='', editing=false, lastDraft=null, lastCtx=null;\r\n  var CLINIC='North Hospital New York';\r\n  var CLINIC_LOGO='';\r\n  function esc(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\r\n  function pad(n){ n=''+n; return n.length<2?'0'+n:n; }\r\n  function genMR(){ var d=new Date(); return 'MR-'+d.getFullYear()+pad(d.getMonth()+1)+pad(d.getDate())+'-'+Math.floor(1000+Math.random()*9000); }\r\n  function fmtProv(p){ p=(p||'').trim(); if(!p) return ''; return /^dr\\.?\\s/i.test(p)?p:('Dr. '+p); }\r\n  function demoBits(){\r\n    var a=ageEl.value.trim(), s=sexEl.value, w=weightEl.value.trim(), parts=[];\r\n    if(a) parts.push(a+' yrs'); if(s) parts.push(s); if(w) parts.push(w+' kg');\r\n    return { label: parts.join(', '), age:a, sex:s, weight:w };\r\n  }\r\n  function initials(name){\r\n    if(!name || name.charAt(0)==='[') return '';\r\n    var w=name.replace(/[^A-Za-z0-9 ]/g,' ').split(/\\s+/).filter(Boolean);\r\n    var skip={of:1,the:1,and:1,for:1,at:1,in:1,on:1};\r\n    var pick=w.filter(function(x){ return !skip[x.toLowerCase()]; });\r\n    return (pick.length?pick:w).slice(0,3).map(function(x){ return x.charAt(0).toUpperCase(); }).join('');\r\n  }\r\n  function makeLogoSVG(name){\r\n    var ini=initials(name), op=ini?'0.22':'1', fs=ini.length>=3?19:26;\r\n    var cross=\"<rect x='28' y='12' width='8' height='40' rx='2' fill='#ffffff' opacity='\"+op+\"'/><rect x='12' y='28' width='40' height='8' rx='2' fill='#ffffff' opacity='\"+op+\"'/>\";\r\n    var text=ini?\"<text x='32' y='41' font-family='Segoe UI,Arial,sans-serif' font-size='\"+fs+\"' font-weight='700' fill='#ffffff' text-anchor='middle'>\"+ini+\"</text>\":\"\";\r\n    return \"<svg xmlns='http://www.w3.org/2000/svg' width='64' height='64' viewBox='0 0 64 64'><defs><linearGradient id='lg' x1='0' y1='0' x2='1' y2='1'><stop offset='0' stop-color='#0d9488'/><stop offset='1' stop-color='#0f766e'/></linearGradient></defs><rect x='2' y='2' width='60' height='60' rx='14' fill='url(#lg)'/>\"+cross+text+\"</svg>\";\r\n  }\r\n  function makeLogoDataUri(name){ return 'data:image/svg+xml;charset=utf-8,'+encodeURIComponent(makeLogoSVG(name)); }\r\n  function logoBadge(px){\r\n    px=px||52; var ini=initials(CLINIC)||'+';\r\n    var fs=Math.round(px*(ini.length>=3?0.32:0.42));\r\n    return '<div style=\"width:'+px+'px;height:'+px+'px;border-radius:12px;background:#0d9488;color:#ffffff;text-align:center;line-height:'+px+'px;font-weight:700;font-size:'+fs+'px;font-family:Segoe UI,Arial,sans-serif;\">'+esc(ini)+'</div>';\r\n  }\r\n  function logoHtml(h){ return logoBadge(h||52); }\r\n  function headHtml(name,mr,provider,dt,demo){\r\n    var pr=fmtProv(provider);\r\n    return '<div class=\"lh\">'+logoHtml(52)+'<div class=\"clinic\">'+esc(CLINIC)+'<small>AI-assisted clinical documentation - physician review required</small></div></div>'+\r\n      '<div class=\"hgrid\"><span><b>Patient:</b> '+esc(name)+'</span><span><b>MR #:</b> '+esc(mr)+'</span>'+\r\n      (demo?'<span><b>Age/Sex/Wt:</b> '+esc(demo)+'</span>':'')+\r\n      (pr?'<span><b>Provider:</b> '+esc(pr)+'</span>':'')+'<span><b>Date:</b> '+esc(dt)+'</span></div>';\r\n  }\r\n  function headTxt(name,mr,provider,dt,demo){\r\n    var pr=fmtProv(provider);\r\n    return CLINIC+'\\nPatient: '+name+'    MR #: '+mr+(demo?'\\nAge/Sex/Wt: '+demo:'')+(pr?'\\nProvider: '+pr:'')+'    Date: '+dt+'\\n----------------------------------------\\n';\r\n  }\r\n  function signHtml(provider,dt){\r\n    var pr=fmtProv(provider)||'____________________';\r\n    return '<div><b>Reviewed &amp; signed by:</b> '+esc(pr)+'</div>'+\r\n      '<div class=\"sigline\">Signature: ______________________&nbsp;&nbsp;&nbsp;&nbsp;Date/Time: '+esc(dt)+'</div>'+\r\n      '<div class=\"disc\">This AI-generated draft must be verified and signed by a licensed physician before entering the medical record.</div>';\r\n  }\r\n  function signTxt(provider,dt){\r\n    var pr=fmtProv(provider)||'____________________';\r\n    return '\\n\\nReviewed & signed by: '+pr+'\\nSignature: ______________________    Date/Time: '+dt;\r\n  }\r\n  function render(note){\r\n    var lines=String(note).split('\\n'), html='';\r\n    for(var k=0;k<lines.length;k++){\r\n      var raw=lines[k], t=raw.trim();\r\n      if(t===''){ html+='<div class=\"sp\"></div>'; continue; }\r\n      if(t.indexOf('TRIAGE:')===0){ continue; }\r\n      if(t.indexOf('SOAP NOTE')===0){ html+='<div class=\"doc-title\">'+esc(t)+'</div>'; continue; }\r\n      if(t.indexOf('**')===0){ html+='<div class=\"alert\">'+esc(t.replace(/\\*\\*/g,'').trim())+'</div>'; continue; }\r\n      if(t.indexOf('Disclaimer:')===0){ html+='<div class=\"disc\">'+esc(t)+'</div>'; continue; }\r\n      if(t.indexOf('Generated:')===0){ html+='<div class=\"meta\">'+esc(t)+'</div>'; continue; }\r\n      if(/^[A-Z] - /.test(t) || t.indexOf('CHIEF COMPLAINT')===0 || t.indexOf('ICD-10')===0 || t.indexOf('Differential Diagnosis')===0 || t.indexOf('RECOMMENDED INVESTIGATIONS')===0 || t.indexOf('SUGGESTED FOLLOW-UP')===0 || t.indexOf('CLINICAL RISK SCORES')===0 || t.indexOf('SUGGESTED PRESCRIPTION')===0){ html+='<div class=\"sec\">'+esc(t)+'</div>'; continue; }\r\n      var indent=(raw.match(/^\\s*/)[0]||'').length;\r\n      html+='<div class=\"ln\" style=\"padding-left:'+(indent*0.5)+'em\">'+esc(t)+'</div>';\r\n    }\r\n    return html;\r\n  }\r\n  function setOutButtons(on){ editBtn.disabled=!on; copyBtn.disabled=!on; pdfBtn.disabled=!on; }\r\n  function applyEdits(){ if(editing){ noteBody=editor.value; bodyEl.innerHTML=render(noteBody); editor.style.display='none'; bodyEl.style.display=''; signEl.style.display=''; editing=false; editBtn.textContent='Edit note'; } }\r\n\r\n  /* ---- Voice dictation: record mic + transcribe via Groq Whisper (reliable, no browser speech service) ---- */\r\n  var TRANSCRIBE_URL=location.origin+'/webhook/soap-transcribe';\r\n  var mediaRec=null, chunks=[], recording=false, micStream=null;\r\n  function micReset(){ recording=false; micBtn.className='mic'; micBtn.textContent='\ud83c\udfa4 Speak'; }\r\n  if(!(navigator.mediaDevices && navigator.mediaDevices.getUserMedia && window.MediaRecorder)){\r\n    micBtn.disabled=true; micBtn.title='Recording not supported in this browser. Use Chrome or Edge.';\r\n  }\r\n  async function sendForTranscription(blob){\r\n    statusEl.textContent='Transcribing your voice...';\r\n    try{\r\n      var fd=new FormData(); fd.append('file', blob, 'audio.webm');\r\n      var r=await fetch(TRANSCRIBE_URL,{method:'POST',body:fd});\r\n      var t=await r.text(); var d; try{ d=JSON.parse(t); }catch(e){ d={text:t}; }\r\n      var tx=(d && d.text)?String(d.text).trim():'';\r\n      if(tx){ bulletsEl.value=(bulletsEl.value?bulletsEl.value.trim()+' ':'')+tx; statusEl.textContent='Transcribed. Review or add more, then Generate.'; }\r\n      else { statusEl.textContent='No speech recognised - try again and speak clearly.'; }\r\n    }catch(e){ statusEl.textContent='Transcription failed: '+e.message; }\r\n  }\r\n  micBtn.addEventListener('click', async function(){\r\n    if(recording){ try{ mediaRec.stop(); }catch(e){} micBtn.textContent='...'; return; }\r\n    statusEl.textContent='Requesting microphone...';\r\n    try{ micStream=await navigator.mediaDevices.getUserMedia({audio:true}); }\r\n    catch(err){\r\n      var nm=(err&&err.name)||'';\r\n      if(nm==='NotAllowedError'||nm==='SecurityError'){ statusEl.textContent='Microphone is blocked by Windows/Chrome. Enable it once (Windows mic privacy: allow desktop apps), reload, then use Speak. You can also just type.'; }\r\n      else if(nm==='NotFoundError'||nm==='DevicesNotFoundError'){ statusEl.textContent='No microphone detected. Connect a mic and check Windows Sound settings.'; }\r\n      else { statusEl.textContent='Microphone unavailable: '+((err&&err.message)||nm||'unknown')+'.'; }\r\n      return;\r\n    }\r\n    chunks=[];\r\n    try{ mediaRec=new MediaRecorder(micStream); }\r\n    catch(e){ try{ mediaRec=new MediaRecorder(micStream,{mimeType:'audio/webm'}); }catch(e2){ statusEl.textContent='Recording not supported here.'; return; } }\r\n    mediaRec.ondataavailable=function(e){ if(e.data && e.data.size) chunks.push(e.data); };\r\n    mediaRec.onstop=function(){\r\n      if(micStream){ micStream.getTracks().forEach(function(t){ t.stop(); }); }\r\n      micReset();\r\n      if(!chunks.length){ statusEl.textContent='No audio captured - try again.'; return; }\r\n      sendForTranscription(new Blob(chunks,{type:(mediaRec.mimeType||'audio/webm')}));\r\n    };\r\n    mediaRec.start(); recording=true; micBtn.className='mic rec'; micBtn.textContent='\u25cf Stop'; statusEl.textContent='Recording... click Stop when finished.';\r\n  });\r\n\r\n  /* ---- Generate ---- */\r\n  btn.addEventListener('click', async function(){\r\n    var name=pname.value.trim();\r\n    if(!name){ statusEl.textContent='Please enter the patient name.'; pname.focus(); return; }\r\n    var mr=mrn.value.trim(); if(!mr){ mr=genMR(); mrn.value=mr; }\r\n    var provider=prov.value.trim();\r\n    var bullets=bulletsEl.value.trim();\r\n    if(!bullets){ statusEl.textContent='Please enter clinical bullet points.'; return; }\r\n    var demo=demoBits();\r\n    var demoLine = demo.label ? ('Patient demographics: '+demo.label) : '';\r\n    var sendBullets = (demoLine?demoLine+'\\n':'')+bullets;\r\n    var dt=new Date().toLocaleString();\r\n    lastMR=mr; editing=false; editor.style.display='none'; bodyEl.style.display='';\r\n    lastCtx={name:name,mr:mr,provider:provider,dt:dt,demo:demo.label};\r\n    btn.disabled=true; setOutButtons(false); rxBtn.disabled=true; handoutBtn.disabled=true;\r\n    statusEl.textContent='Generating draft...'; paper.className='paper';\r\n    try{\r\n      var res=await fetch(window.location.href,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({bullets:sendBullets,patient_name:name,mr_number:mr,provider:provider,age:demo.age,sex:demo.sex,weight:demo.weight,patient_context:{allergies:[],active_medications:[]}})});\r\n      var text=await res.text();\r\n      if(!text) throw new Error('Empty response from server. Check n8n Executions.');\r\n      var data; try{ data=JSON.parse(text); }catch(e){ throw new Error('Non-JSON response: '+text.slice(0,200)); }\r\n      if(data && data.formatted_note){\r\n        lastDraft=data.draft||{};\r\n        var tri=lastDraft.triage||null, banner='';\r\n        if(tri&&tri.level){ var lv=String(tri.level).toLowerCase(); var cls=lv.indexOf('emerg')>=0?'triage-emergency':(lv.indexOf('urgent')>=0?'triage-urgent':'triage-routine'); banner='<div class=\"triage '+cls+'\">TRIAGE: '+esc(tri.level)+(tri.rationale&&tri.rationale!=='[not documented]'?' - '+esc(tri.rationale):'')+'</div>'; }\r\n        noteBody=data.formatted_note;\r\n        headerText=headTxt(name,mr,provider,dt,demo.label);\r\n        signText=signTxt(provider,dt);\r\n        phead.innerHTML=headHtml(name,mr,provider,dt,demo.label);\r\n        bodyEl.innerHTML=banner+render(noteBody);\r\n        signEl.innerHTML=signHtml(provider,dt); signEl.style.display='';\r\n        paper.className='paper show'; setOutButtons(true);\r\n        rxBtn.disabled=!(lastDraft.prescription&&lastDraft.prescription.length);\r\n        var pi=lastDraft.patient_instructions||{}; handoutBtn.disabled=!((pi.english||'').trim()||(pi.urdu||'').trim());\r\n        statusEl.textContent='Draft generated. Review, edit if needed, then sign.';\r\n      }\r\n      else if(data && data.success===false){ noteBody=''; lastDraft=null; phead.innerHTML=''; signEl.innerHTML=''; signEl.style.display='none'; bodyEl.innerHTML='<div class=\"alert\">'+esc(data.error||'Error')+'</div>'+(data.hint?'<div class=\"ln\">'+esc(data.hint)+'</div>':''); paper.className='paper show'; statusEl.textContent='Could not generate.'; }\r\n      else { phead.innerHTML=''; signEl.innerHTML=''; signEl.style.display='none'; bodyEl.innerHTML='<pre>'+esc(JSON.stringify(data,null,2))+'</pre>'; paper.className='paper show'; statusEl.textContent='Done.'; }\r\n    }catch(e){ statusEl.textContent='Request failed: '+e.message; }\r\n    finally{ btn.disabled=false; }\r\n  });\r\n\r\n  /* ---- Edit ---- */\r\n  editBtn.addEventListener('click', function(){\r\n    if(!noteBody) return;\r\n    if(!editing){ editor.value=noteBody; editor.style.display='block'; bodyEl.style.display='none'; signEl.style.display='none'; editing=true; editBtn.textContent='Apply edits'; statusEl.textContent='Editing note - click \"Apply edits\" when done.'; editor.focus(); }\r\n    else { applyEdits(); statusEl.textContent='Edits applied.'; }\r\n  });\r\n\r\n  /* ---- Copy ---- */\r\n  copyBtn.addEventListener('click', function(){ applyEdits(); if(noteBody){ navigator.clipboard.writeText(headerText+noteBody+signText); statusEl.textContent='Note copied to clipboard.'; } });\r\n\r\n  /* ---- PDF (native print - works in all browsers) ---- */\r\n  pdfBtn.addEventListener('click', function(){\r\n    applyEdits();\r\n    if(paper.className.indexOf('show')<0){ statusEl.textContent='Generate a note first.'; return; }\r\n    printHtml(phead.innerHTML + bodyEl.innerHTML + signEl.innerHTML);\r\n  });\r\n\r\n  /* ---- Document PDF helpers (inline styles so html2pdf renders reliably) ---- */\r\n  function docHeaderInline(){\r\n    var c=lastCtx||{};\r\n    var logo=logoBadge(52);\r\n    return '<div style=\"display:flex;align-items:center;gap:12px;border-bottom:2px solid #e2e8f0;padding-bottom:8px;\">'+logo+\r\n      '<div style=\"font-weight:700;font-size:18px;color:#0f172a;\">'+esc(CLINIC)+'<div style=\"font-weight:400;color:#64748b;font-size:12px;\">AI-assisted - physician review required</div></div></div>'+\r\n      '<div style=\"font-size:14px;color:#334155;margin:10px 0;\"><b>Patient:</b> '+esc(c.name||'')+' &nbsp;&nbsp; <b>MR #:</b> '+esc(c.mr||'')+(c.demo?' &nbsp;&nbsp; <b>Age/Sex/Wt:</b> '+esc(c.demo):'')+'<br><b>Provider:</b> '+esc(fmtProv(c.provider)||'____________')+' &nbsp;&nbsp; <b>Date:</b> '+esc(c.dt||'')+'</div>';\r\n  }\r\n  function docSignInline(){\r\n    var c=lastCtx||{};\r\n    return '<div style=\"margin-top:26px;padding-top:8px;border-top:1px dashed #94a3b8;font-size:14px;color:#0f172a;\"><b>Reviewed &amp; signed by:</b> '+esc(fmtProv(c.provider)||'____________________')+'<br>Signature: ______________________ &nbsp;&nbsp; Date/Time: '+esc(c.dt||'')+'<div style=\"color:#64748b;font-style:italic;font-size:12px;margin-top:6px;\">Physician verification required before use.</div></div>';\r\n  }\r\n  function printHtml(inner){\r\n    var pa=$('printarea');\r\n    pa.innerHTML='<div style=\"font-family:Segoe UI,system-ui,sans-serif;line-height:1.5;color:#0f172a;\">'+inner+'</div>';\r\n    document.body.classList.add('printing-doc');\r\n    var cleaned=false;\r\n    function done(){ if(cleaned) return; cleaned=true; document.body.classList.remove('printing-doc'); pa.innerHTML=''; window.removeEventListener('afterprint', done); }\r\n    window.addEventListener('afterprint', done);\r\n    statusEl.textContent='Opening print dialog - choose \"Save as PDF\" (or \"Microsoft Print to PDF\") as the printer.';\r\n    setTimeout(function(){ try{ window.print(); }catch(e){ done(); statusEl.textContent='Could not open print dialog.'; } }, 150);\r\n    setTimeout(done, 120000);\r\n  }\r\n\r\n  /* ---- Rx slip PDF ---- */\r\n  rxBtn.addEventListener('click', function(){\r\n    var rx=(lastDraft&&lastDraft.prescription)||[];\r\n    if(!rx.length){ statusEl.textContent='No prescription suggestions available.'; return; }\r\n    var td='border:1px solid #cbd5e1;padding:6px 8px;text-align:left;font-size:13px;';\r\n    var th='border:1px solid #cbd5e1;padding:6px 8px;text-align:left;font-size:13px;background:#f1f5f9;';\r\n    var rows='';\r\n    for(var i=0;i<rx.length;i++){ var r=rx[i]||{}; rows+='<tr><td style=\"'+td+'\">'+(i+1)+'</td><td style=\"'+td+'\">'+esc(r.drug||'')+'</td><td style=\"'+td+'\">'+esc(r.dose||'')+'</td><td style=\"'+td+'\">'+esc(r.route||'')+'</td><td style=\"'+td+'\">'+esc(r.frequency||'')+'</td><td style=\"'+td+'\">'+esc(r.duration||'')+'</td><td style=\"'+td+'\">'+esc(r.notes||'')+'</td></tr>'; }\r\n    var inner=docHeaderInline()+\r\n      '<h2 style=\"color:#0f766e;font-size:18px;margin:14px 0 6px;\">Prescription (Rx) - suggested, for physician approval</h2>'+\r\n      '<table style=\"width:100%;border-collapse:collapse;margin-top:8px;\"><thead><tr><th style=\"'+th+'\">#</th><th style=\"'+th+'\">Drug</th><th style=\"'+th+'\">Dose</th><th style=\"'+th+'\">Route</th><th style=\"'+th+'\">Frequency</th><th style=\"'+th+'\">Duration</th><th style=\"'+th+'\">Notes</th></tr></thead><tbody>'+rows+'</tbody></table>'+\r\n      docSignInline();\r\n    printHtml(inner);\r\n  });\r\n\r\n  /* ---- Patient handout PDF (English + Urdu) ---- */\r\n  handoutBtn.addEventListener('click', function(){\r\n    var pi=(lastDraft&&lastDraft.patient_instructions)||{};\r\n    var en=(pi.english||'').trim(), ur=(pi.urdu||'').trim();\r\n    if(!en&&!ur){ statusEl.textContent='No patient instructions available.'; return; }\r\n    var inner=docHeaderInline()+'<h2 style=\"color:#0f766e;font-size:18px;margin:14px 0 6px;\">Patient Instructions</h2>';\r\n    if(en){ inner+='<div style=\"font-size:15px;color:#0f172a;\">'+esc(en).replace(/\\n/g,'<br>')+'</div>'; }\r\n    if(ur){ inner+='<h2 style=\"color:#0f766e;font-size:18px;margin:16px 0 6px;\">\u0645\u0631\u06cc\u0636 \u06a9\u06d2 \u0644\u06cc\u06d2 \u06c1\u062f\u0627\u06cc\u0627\u062a</h2><div style=\"direction:rtl;text-align:right;font-size:17px;color:#0f172a;\">'+esc(ur).replace(/\\n/g,'<br>')+'</div>'; }\r\n    inner+='<div style=\"color:#64748b;font-style:italic;font-size:12px;margin-top:16px;\">Given by: '+esc(fmtProv(lastCtx&&lastCtx.provider)||CLINIC)+'</div>';\r\n    printHtml(inner);\r\n  });\r\n</script>\r\n</body>\r\n</html>\r\n",
